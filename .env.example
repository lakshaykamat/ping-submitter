# Flask
FLASK_APP=app:create_app
FLASK_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=dev

# Storage and paths
DATABASE_URL=sqlite:///app.db
REPORT_DIR=reports
ARTIFACT_DIR=reports/artifacts
BROWSER_PROFILE_DIR=browser_profiles
SITES_CONFIG_PATH=config/sites.yaml

# Skyvern (run: docker exec skyvern-skyvern-1 cat /app/.skyvern/credentials.toml)
SKYVERN_BASE_URL=http://localhost:8001
SKYVERN_API_KEY=
SKYVERN_MAX_STEPS=50
SKYVERN_POLL_INTERVAL_SECONDS=5.0
SKYVERN_TASK_TIMEOUT_SECONDS=3600.0
SKYVERN_RECORD_SESSION=false

# Submission behaviour
SUBMISSION_EMAIL=
CAPTCHA_POLICY_DEFAULT=solve
AGENTIC_PRE_ATTEMPT_DELAY_SECONDS=1.0
